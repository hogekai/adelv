  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "happy-dom": "^17.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
